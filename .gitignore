# Local environment variables (never commit secrets)
.env
# Byte-compiled / optimized / DLLs
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Installer / pip
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/

# Virtual environments
venv/
ENV/
env/
.venv/
.env/

# IDEs / editors
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# SQLite databases (persist data/ dir structure but not the DB itself)
data/*.db
data/*.sqlite3

# Compiled Python
*.pyc

# Lockfiles
Pipfile.lock

# Other
*.bak
*.tmp